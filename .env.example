# Copy to .env — loaded by docker compose (env_file).

# Host ports
WHALE2API_HOST_PORT=5103
POOL_UI_HOST_PORT=5010

# Pool WebUI login (required)
POOL_UI_ADMIN_TOKEN=change-me-pool-ui

# SQLite database file (whale2api + poolui must use the same path)
# WHALE2API_DATABASE_PATH=docker-data/whale2api/whale2api.db

# Optional: cap accounts per gateway key (0 = unlimited)
# WHALE2API_POOL_MAX_ACCOUNTS_PER_KEY=0

# Disable appending the default thinking prompt to user messages (when request thinking=true)
WHALE2API_THINKING_INJECTION_ENABLED=0
